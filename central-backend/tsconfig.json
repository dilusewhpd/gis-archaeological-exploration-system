{
  "compilerOptions": {
    /* Language */
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    /* Project */
    // "rootDir": "./src",
    "outDir": "./dist",

    /* Node */
    "types": ["node"],
    "lib": ["ES2022"],

    /* Interop */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    /* Type Checking */
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    /* Output */
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    /* Misc */
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": [
    "src",
    "prisma",
    "prisma.config.ts"
, "src/generated"  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}